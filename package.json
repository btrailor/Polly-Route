    "proxy",
    "openclaw",
    "ollama",
    "agent",
    "vault",
    "rag"
  ],
  "author": "Brett Gershon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/brettgershon/polly-router/issues"
  },
  "homepage": "https://github.com/brettgershon/polly-router#readme",
  "dependencies": {},
  "devDependencies": {
    "typescript": "^5.4.0",
    "@types/node": "^20.0.0",
    "jest": "^29.0.0",
    "@jest/globals": "^29.0.0",
    "ts-jest": "^29.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
